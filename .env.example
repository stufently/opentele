# opentele-ng — environment variables template
#
# Copy this file to ``.env`` and fill in real values. ``.env`` is gitignored
# so credentials never leak into the repo. Loaded by ``scripts/publish.sh``
# (and by anything else that runs ``set -a && . .env && set +a``).
#
# ---------------------------------------------------------------------------
# PyPI publishing (required to upload a new release)
# ---------------------------------------------------------------------------
#
# Create the token at https://pypi.org/manage/account/token/ — choose
# "Scope: project: opentele-ng" once the first manual upload is done, or
# "Entire account" for the very first upload.
#
# The username is always literal ``__token__`` when authenticating with an
# API token; the password is the ``pypi-<...>`` string below.
PYPI_API_TOKEN=pypi-AgEIcHlwaS5vcmcCJ...replace-me

# Test PyPI (https://test.pypi.org/) — useful for dry-run uploads.
TEST_PYPI_API_TOKEN=pypi-AgENdGVzdC5weXBpLm9yZwIkY...replace-me

# ---------------------------------------------------------------------------
# Optional — opt-in real-tdata smoke test
# ---------------------------------------------------------------------------
# Absolute path to a real Telegram Desktop ``tdata`` folder. When set,
# tests/integration/test_real_tdata_smoke.py runs (otherwise skipped).
# CI never sets this.
# OPENTELE_REAL_TDATA_PATH=/home/you/Telegram Desktop/tdata
