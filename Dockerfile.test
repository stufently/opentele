# Pinned digest for reproducible test builds.
ARG PY_VERSION=3.14
ARG PY_BASE=python:3.14-slim@sha256:a7185a8e40af01bf891414a4df16ef10fc6000cee460a404a13da9029fe41604
FROM ${PY_BASE}

# PyQt6 runtime deps for Linux
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgl1 \
    libegl1 \
    libxkbcommon-x11-0 \
    libdbus-1-3 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml requirements.txt requirements-test.txt README.md MANIFEST.in LICENSE ./
COPY src/ ./src/
COPY tests/ ./tests/
COPY docs/ ./docs/

RUN pip install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir -e ".[test]"

# tdata_test.py — live integration test, requires real Telegram auth, excluded from CI
CMD ["pytest", "-v", "--tb=short", "--ignore=tests/tdata_test.py", "tests/"]
